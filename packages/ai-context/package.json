{
  "name": "@futuremod/ai-context",
  "version": "0.1.0",
  "description": "AI-native registry metadata for @futuremod/ui — shadcn-compatible",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./registry.json": "./dist/registry.json",
    "./llms.txt": "./dist/llms.txt",
    "./llms-full.txt": "./dist/llms-full.txt"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/generate.js",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.4.5"
  }
}