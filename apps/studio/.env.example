# Apex domain for subdomain parsing (default: futuremod.site).
# VITE_FUTUREMOD_ROOT_DOMAIN=futuremod.site

# Optional: act as a named project host while developing (same slug as acme.futuremod.site).
# VITE_FUTUREMOD_PROJECT_SLUG=acme

# Supabase — required for auth. Find these in Supabase dashboard → Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Optional: Postgres URI for `pnpm migrate:supabase` (repo root). Use Session pooler — not direct `db.*:5432`
# (direct DB often uses IPv6 and fails with "no route to host" on some networks).
# Dashboard → Database → Connection string → URI → Method: Session pooler.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
