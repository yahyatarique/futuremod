# Apex domain for subdomain parsing (default: futuremod.site).
# VITE_FUTUREMOD_ROOT_DOMAIN=futuremod.site

# Optional: act as a named project host while developing (same slug as acme.futuremod.site).
# VITE_FUTUREMOD_PROJECT_SLUG=acme

# Supabase — required for auth. Find these in Supabase dashboard → Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
